# =============================================================================
# YAMTRACK STACK — media tracker configuration
# Copy to .env and fill in values before starting this stack.
# Database credentials must match the databases stack.
# =============================================================================

# Domain
YAMTRACK_DOMAIN=yamtrack.example.com

# Image tag
YAMTRACK_TAG=latest

# Secret key (required) — generate with: openssl rand -hex 32
YAMTRACK_SECRET=change_me_to_a_random_string

# PostgreSQL connection (must match databases stack)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=fuelrod
POSTGRES_PASSWORD=change_me
YAMTRACK_DB=yamtrack

# Redis connection (must match cache stack)
YAMTRACK_REDIS_URL=redis://cache:6379
