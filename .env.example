# =============================================================================
# General
# =============================================================================
TZ=UTC

# =============================================================================
# Postgres (stacks/core.yml)
# =============================================================================
POSTGRES_USER=media
POSTGRES_PASSWORD=change_me
POSTGRES_DB=media

# =============================================================================
# Yamtrack (stacks/tracking.yml)
# =============================================================================
YAMTRACK_TAG=latest

# =============================================================================
# Navidrome (stacks/media-servers.yml)
# =============================================================================
ND_SCANINTERVAL=1h
ND_LOGLEVEL=info

# =============================================================================
# Paperless-ngx (stacks/documents.yml)
# =============================================================================
PAPERLESS_DBNAME=paperless
PAPERLESS_SECRET_KEY=generate_a_random_secret_key_here
PAPERLESS_URL=http://localhost:8010
PAPERLESS_OCR_LANGUAGE=eng
